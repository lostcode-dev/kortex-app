# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# PostHog (client-side, production only)
# Set to true only in production environments where analytics should be enabled
NUXT_PUBLIC_POSTHOG_ENABLED=false
# Example: phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NUXT_PUBLIC_POSTHOG_KEY=
# Example: https://us.i.posthog.com
NUXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase (server-side only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY= your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe (server-side only)
STRIPE_SECRET_KEY=
# Comma-separated allowlist (ex: price_123,price_456)
STRIPE_ALLOWED_PRICE_IDS=
# Optional: if you created a custom portal configuration
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
