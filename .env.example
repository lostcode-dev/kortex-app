# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# OneSignal (client-side, production only)
# Set to true only in production environments where push/web notifications should be enabled
NUXT_PUBLIC_ONESIGNAL_ENABLED=false
# Example: 11111111-2222-3333-4444-555555555555
NUXT_PUBLIC_ONESIGNAL_APP_ID=
# Keep defaults unless you intentionally move the OneSignal service worker files
NUXT_PUBLIC_ONESIGNAL_SERVICE_WORKER_PATH=/push/onesignal/OneSignalSDKWorker.js
NUXT_PUBLIC_ONESIGNAL_SERVICE_WORKER_UPDATER_PATH=/push/onesignal/OneSignalSDKUpdaterWorker.js
NUXT_PUBLIC_ONESIGNAL_SERVICE_WORKER_SCOPE=/push/onesignal/

# PostHog (client-side, production only)
# Set to true only in production environments where analytics should be enabled
NUXT_PUBLIC_POSTHOG_ENABLED=false
# Example: phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NUXT_PUBLIC_POSTHOG_KEY=
# Example: https://us.i.posthog.com
NUXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase (server-side only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY= your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe (server-side only)
STRIPE_SECRET_KEY=
# Comma-separated allowlist (ex: price_123,price_456)
STRIPE_ALLOWED_PRICE_IDS=
# Optional: if you created a custom portal configuration
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
