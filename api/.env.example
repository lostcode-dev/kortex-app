# Server
PORT=4000
NODE_ENV=development

# Supabase (server-side only — use service role key)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Timezone for cron jobs (IANA timezone)
TZ=Europe/Lisbon

# Cron schedule for close-day job (default: 23:55 daily)
CRON_CLOSE_DAY_SCHEDULE=55 23 * * *

# Token used to trigger manual jobs via HTTP (Bearer token)
JOB_TRIGGER_TOKEN=replace-with-a-random-secret-min-16-chars

# Batch sizes for large close-day processing
CLOSE_DAY_FETCH_BATCH_SIZE=500
CLOSE_DAY_UPSERT_BATCH_SIZE=200
